<% content_for :title, "Editor — #{@payload[:election][:label]}" %>

<style>
  /* Spreadsheet grid styles (cell classes are generated in the React bundle) */
  .ee-grid { border-collapse: separate; border-spacing: 0; }
  .ee-grid th, .ee-grid td {
    border-right: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
    padding: 0;
    background: var(--row-bg, #fff); /* tinted per contest party from the row */
  }
  .ee-grid thead th {
    position: sticky; top: 0; z-index: 20;
    background: #f9fafb;
    padding: 8px 10px;
    font-size: 11px; font-weight: 600; color: #4b5563;
    text-transform: uppercase; letter-spacing: 0.03em;
    text-align: left; white-space: nowrap;
  }
  .ee-grid tr:hover td { background: color-mix(in srgb, var(--row-bg, #fff) 88%, #475569 12%); }
  .ee-grid tr.ee-row-error td { background: #fee2e2; }

  /* Sticky left columns: status · contest · first · middle · last · suffix */
  .ee-grid .ee-c0 { position: sticky; left: 0;     z-index: 10; min-width: 36px;  max-width: 36px; }
  .ee-grid .ee-c1 { position: sticky; left: 36px;  z-index: 10; min-width: 220px; max-width: 220px; }
  .ee-grid .ee-c2 { position: sticky; left: 256px; z-index: 10; min-width: 110px; max-width: 110px; }
  .ee-grid .ee-c3 { position: sticky; left: 366px; z-index: 10; min-width: 64px;  max-width: 64px; }
  .ee-grid .ee-c4 { position: sticky; left: 430px; z-index: 10; min-width: 120px; max-width: 120px; }
  .ee-grid .ee-c5 { position: sticky; left: 550px; z-index: 10; min-width: 52px;  max-width: 52px;
                    border-right: 2px solid #d1d5db; box-shadow: 4px 0 6px -4px rgb(0 0 0 / 0.15); }
  .ee-grid thead .ee-c0, .ee-grid thead .ee-c1, .ee-grid thead .ee-c2,
  .ee-grid thead .ee-c3, .ee-grid thead .ee-c4, .ee-grid thead .ee-c5 { z-index: 30; }

  .ee-cell {
    width: 100%; border: 0; background: transparent;
    padding: 7px 10px; font-size: 13px; line-height: 1.25rem;
    outline: none; box-shadow: none; border-radius: 0;
  }
  .ee-cell:focus { background: #fff; box-shadow: inset 0 0 0 2px #3b82f6; position: relative; z-index: 5; }
  select.ee-cell { padding-right: 26px; cursor: pointer; appearance: auto; }
  .ee-cell::placeholder { color: #d1d5db; }
  .ee-cell-invalid { box-shadow: inset 0 0 0 2px #f87171 !important; }

  .ee-social-cell { position: relative; min-width: 150px; }
  .ee-social-cell .ee-cell { font-size: 11px; padding-right: 44px; }

  .ee-status-dot { width: 10px; height: 10px; border-radius: 9999px; margin: 0 auto; display: block; }
</style>

<script type="application/json" id="editor-data"><%= raw @payload.to_json %></script>
<div id="election-editor-root"></div>
