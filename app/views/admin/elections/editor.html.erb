<div class="space-y-6" data-controller="election-editor">
  <!-- Header -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h2 class="text-xl font-bold text-gray-900"><%= @election.year %> <%= @election.election_type.titleize %> Election</h2>
    <p class="text-sm text-gray-500 mt-1">Quick bulk entry for candidates and social media handles</p>
  </div>

  <!-- Ballot/Contest Selector -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <div class="grid grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">State</label>
        <select class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" data-action="change->election-editor#onStateChange">
          <option value="">-- Select State --</option>
          <% @states.each do |state| %>
            <option value="<%= state.id %>"><%= state.name %> (<%= state.abbreviation %>)</option>
          <% end %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Ballot Type</label>
        <select class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" data-action="change->election-editor#onBallotTypeChange">
          <option value="">-- Select Type --</option>
          <option value="primary">Primary</option>
          <option value="general">General</option>
          <option value="special">Special</option>
          <option value="runoff">Runoff</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Contest/Office</label>
        <select class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" data-action="change->election-editor#onContestChange">
          <option value="">-- Select Contest --</option>
          <% @ballots.each do |ballot| %>
            <% ballot.contests.each do |contest| %>
              <option value="<%= contest.id %>"><%= contest.office.title %></option>
            <% end %>
          <% end %>
        </select>
      </div>
    </div>
  </div>

  <!-- Candidates Spreadsheet -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm" data-table="candidates">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left font-semibold text-gray-700">Name</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700">Party</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700">Outcome</th>
            <th class="px-4 py-3 text-center font-semibold text-gray-700">Incumbent</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 bg-blue-50">Facebook</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 bg-blue-50">Twitter</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 bg-blue-50">Instagram</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 bg-blue-50">YouTube</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 bg-blue-50">TikTok</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 bg-blue-50">BlueSky</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 bg-blue-50">TruthSocial</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 bg-blue-50">Gettr</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 bg-blue-50">Rumble</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 bg-blue-50">Telegram</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 bg-blue-50">Threads</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-700">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200" data-tbody="candidates">
          <!-- Candidates will be populated here -->
          <tr class="hover:bg-gray-50">
            <td colspan="16" class="px-4 py-8 text-center text-gray-500">
              Select a state, ballot type, and contest above to see candidates
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Add Row Button -->
    <div class="border-t border-gray-200 px-4 py-3 bg-gray-50 flex justify-between items-center">
      <button
        type="button"
        class="inline-flex items-center px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50"
        data-action="click->election-editor#addCandidateRow"
      >
        + Add Candidate Row
      </button>
      <span class="text-xs text-gray-500" data-count="row-count">0 candidates</span>
    </div>
  </div>

  <!-- Save Actions -->
  <div class="flex gap-3 sticky bottom-6">
    <button
      type="button"
      class="flex-1 inline-flex justify-center items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700"
      data-action="click->election-editor#saveAll"
    >
      Save All Changes
    </button>
    <a
      href="<%= admin_elections_path %>"
      class="inline-flex justify-center items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50"
    >
      Cancel
    </a>
  </div>
</div>

<!-- Candidate Row Template -->
<template id="candidate-row-template">
  <tr class="hover:bg-gray-50" data-candidate-id="">
    <!-- Name -->
    <td class="px-4 py-3">
      <input
        type="text"
        placeholder="Candidate name"
        class="w-full rounded border border-gray-300 px-2 py-1 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
        data-field="name"
      />
    </td>

    <!-- Party -->
    <td class="px-4 py-3">
      <select class="w-full rounded border border-gray-300 px-2 py-1 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500" data-field="party">
        <option value="">-- Party --</option>
        <% @parties.each do |party| %>
          <option value="<%= party.id %>"><%= party.name %></option>
        <% end %>
      </select>
    </td>

    <!-- Outcome -->
    <td class="px-4 py-3">
      <select class="w-full rounded border border-gray-300 px-2 py-1 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500" data-field="outcome">
        <option value="pending">Pending</option>
        <option value="won">Won</option>
        <option value="lost">Lost</option>
        <option value="withdrawn">Withdrawn</option>
      </select>
    </td>

    <!-- Incumbent -->
    <td class="px-4 py-3 text-center">
      <input type="checkbox" class="rounded border-gray-300" data-field="incumbent" />
    </td>

    <!-- Social Media Platforms -->
    <% SocialMediaAccount::PLATFORMS.each do |platform| %>
      <td class="px-4 py-3 bg-blue-50">
        <input
          type="text"
          placeholder="@handle"
          class="w-full rounded border border-gray-300 px-2 py-1 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
          data-field="<%= platform.downcase %>"
          title="<%= platform %> handle"
        />
      </td>
    <% end %>

    <!-- Actions -->
    <td class="px-4 py-3 text-right">
      <button
        type="button"
        class="text-red-600 hover:text-red-800 text-sm font-medium"
        data-action="click->election-editor#deleteRow"
        title="Delete this candidate"
      >
        Delete
      </button>
    </td>
  </tr>
</template>
