<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Offices</h1>
    <%= link_to "New Office", new_admin_office_path, class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-lg shadow mb-6 p-4">
    <%= form_with url: admin_offices_path, method: :get, class: "flex flex-wrap gap-4 items-end" do |f| %>
      <div class="flex-1 min-w-[200px]">
        <label class="block text-sm font-medium text-gray-700 mb-1">Search</label>
        <%= text_field_tag :q, params[:q], placeholder: "Title, seat, body, or category…", class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Level</label>
        <%= select_tag :level, options_for_select([['All Levels', '']] + @levels.map { |l| [l.titleize, l] }, params[:level]), class: "px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Branch</label>
        <%= select_tag :branch, options_for_select([['All Branches', '']] + @branches.map { |b| [b.titleize, b] }, params[:branch]), class: "px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">State</label>
        <%= select_tag :state, options_for_select([['All States', '']] + @states, params[:state]), class: "px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
        <%= select_tag :category, options_for_select([['All Categories', '']] + @categories, params[:category]), class: "px-3 py-2 border border-gray-300 rounded-md max-w-[200px]" %>
      </div>
      <div>
        <%= submit_tag "Filter", class: "px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300 cursor-pointer" %>
      </div>
      <% if params[:q].present? || params[:level].present? || params[:branch].present? || params[:state].present? || params[:category].present? %>
        <div><%= link_to "Clear", admin_offices_path, class: "px-4 py-2 text-gray-600 hover:text-gray-900" %></div>
      <% end %>
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Level / Branch</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">State</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Body</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">District</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @offices.each do |office| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <%= link_to office.title, admin_office_path(office), class: "text-blue-600 hover:text-blue-800 font-medium" %>
              <% if office.seat.present? %>
                <span class="text-gray-500 text-sm">(<%= office.seat %>)</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-gray-600 text-sm"><%= office.office_category %></td>
            <td class="px-6 py-4">
              <span class="px-2 py-1 text-xs rounded-full bg-gray-100 text-gray-800"><%= office.level&.titleize %></span>
              <% if office.branch.present? %><span class="text-xs text-gray-500 ml-1"><%= office.branch.titleize %></span><% end %>
            </td>
            <td class="px-6 py-4 text-gray-600"><%= office.state %></td>
            <td class="px-6 py-4 text-gray-600 text-sm"><%= office.body_name %></td>
            <td class="px-6 py-4 text-gray-600 text-sm">
              <% if office.district %>
                <%= link_to office.district.full_name, admin_district_path(office.district), class: "text-blue-600 hover:text-blue-800" %>
              <% else %>
                <span class="text-gray-400">—</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right">
              <%= link_to "Edit", edit_admin_office_path(office), class: "text-blue-600 hover:text-blue-800" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-4">
    <%= paginate @offices %>
  </div>
</div>
