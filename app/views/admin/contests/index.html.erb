<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Contests</h1>
    <%= link_to "New Contest", new_admin_contest_path, class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-lg shadow mb-6 p-4">
    <%= form_with url: admin_contests_path, method: :get, class: "flex flex-wrap gap-4 items-end" do |f| %>
      <div class="flex-1 min-w-[180px]">
        <label class="block text-sm font-medium text-gray-700 mb-1">Search Office</label>
        <%= text_field_tag :q, params[:q], placeholder: "Title or seat…", class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">State</label>
        <%= select_tag :state, options_for_select([['All States', '']] + @states, params[:state]), class: "px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Party</label>
        <%= select_tag :party, options_for_select([['All Parties', '']] + @parties, params[:party]), class: "px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">District #</label>
        <%= number_field_tag :district_number, params[:district_number], placeholder: "88", class: "w-24 px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
        <%= select_tag :contest_type, options_for_select([['All Types', '']] + @contest_types.map { |t| [t.titleize, t] }, params[:contest_type]), class: "px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Year</label>
        <%= select_tag :year, options_for_select([['All Years', '']] + @years.map { |y| [y, y] }, params[:year].presence&.to_i), class: "px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <%= submit_tag "Filter", class: "px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300 cursor-pointer" %>
      </div>
      <% if [:q, :state, :party, :district_number, :contest_type, :year].any? { |k| params[k].present? } %>
        <div><%= link_to "Clear", admin_contests_path, class: "px-4 py-2 text-gray-600 hover:text-gray-900" %></div>
      <% end %>
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Office</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">State</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">District</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Party</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ballot / Election</th>
          <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Cand.</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @contests.each do |contest| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <%= link_to admin_contest_path(contest), class: "text-blue-600 hover:text-blue-800 font-medium" do %>
                <%= contest.office.title %><% if contest.office.seat.present? %> <span class="text-gray-500 font-normal">(<%= contest.office.seat %>)</span><% end %>
              <% end %>
              <div class="text-xs text-gray-400"><%= contest.date.strftime('%b %d, %Y') %></div>
            </td>
            <td class="px-6 py-4 text-gray-600"><%= contest.ballot&.state %></td>
            <td class="px-6 py-4 text-gray-600 text-sm">
              <% if contest.office.district %>
                <%= link_to contest.office.district.full_name, admin_district_path(contest.office.district), class: "text-blue-600 hover:text-blue-800" %>
              <% else %>
                <span class="text-gray-400">—</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-gray-600"><%= contest.party.presence || '—' %></td>
            <td class="px-6 py-4">
              <span class="px-2 py-1 text-xs rounded-full bg-blue-100 text-blue-800"><%= contest.contest_type&.titleize %></span>
            </td>
            <td class="px-6 py-4 text-sm">
              <% if contest.ballot %>
                <%= link_to contest.ballot.full_name, admin_ballot_path(contest.ballot), class: "text-blue-600 hover:text-blue-800" %>
                <% if contest.ballot.election %>
                  <div class="text-xs text-gray-400"><%= link_to contest.ballot.election.full_name, admin_election_path(contest.ballot.election), class: "text-gray-500 hover:text-gray-700" %></div>
                <% end %>
              <% else %>
                <span class="text-gray-400">—</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-center text-gray-600"><%= contest.candidates.size %></td>
            <td class="px-6 py-4 text-right">
              <%= link_to "Edit", edit_admin_contest_path(contest), class: "text-blue-600 hover:text-blue-800" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-4">
    <%= paginate @contests %>
  </div>
</div>
