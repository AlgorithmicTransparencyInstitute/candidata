<%= form_with model: [:admin, contest], class: "bg-white rounded-lg shadow p-6" do |f| %>
  <% if contest.errors.any? %>
    <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded">
      <ul class="list-disc list-inside text-red-700 text-sm">
        <% contest.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4" data-controller="office-search" data-office-search-url-value="<%= search_admin_offices_path %>">
    <label class="block text-sm font-medium text-gray-700 mb-1">Office</label>
    <%= f.hidden_field :office_id, data: { office_search_target: "hidden" } %>
    <div class="relative">
      <%= text_field_tag :office_search, contest.office&.search_label,
            placeholder: "Search offices by title, seat, body, or state…",
            autocomplete: "off",
            data: { office_search_target: "input",
                    action: "input->office-search#onInput keydown->office-search#onKeydown blur->office-search#onBlur" },
            class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
      <div data-office-search-target="results"
           class="hidden absolute z-10 mt-1 w-full max-h-72 overflow-auto bg-white border border-gray-200 rounded-md shadow-lg"></div>
    </div>
    <p class="text-xs text-gray-500 mt-1">Type at least 2 characters — searches every office in the database.</p>
  </div>

  <div class="mb-4">
    <label class="block text-sm font-medium text-gray-700 mb-1">Ballot</label>
    <%= f.collection_select :ballot_id, @ballots, :id, :full_name, { include_blank: 'Select ballot' }, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
  </div>

  <div class="grid grid-cols-2 gap-4 mb-4">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Date</label>
      <%= f.date_field :date, class: "w-full px-3 py-2 border border-gray-300 rounded-md", required: true %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Contest Type</label>
      <%= f.select :contest_type, ['general', 'primary', 'runoff', 'special'].map { |t| [t.titleize, t] }, { include_blank: 'Select type' }, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    </div>
  </div>

  <div class="mb-4">
    <label class="block text-sm font-medium text-gray-700 mb-1">Party</label>
    <%= f.select :party, @party_options, { include_blank: 'No party / nonpartisan' }, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    <p class="text-xs text-gray-500 mt-1">Required for primary contests.</p>
  </div>

  <div class="mb-4">
    <label class="block text-sm font-medium text-gray-700 mb-1">Location</label>
    <%= f.text_field :location, class: "w-full px-3 py-2 border border-gray-300 rounded-md", placeholder: "State or jurisdiction" %>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", contest.persisted? ? admin_contest_path(contest) : admin_contests_path, class: "px-4 py-2 text-gray-700 hover:text-gray-900" %>
    <%= f.submit contest.persisted? ? "Save Changes" : "Create Contest", class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 cursor-pointer" %>
  </div>
<% end %>
