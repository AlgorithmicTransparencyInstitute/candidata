<%= form_with model: [:admin, ballot], class: "bg-white rounded-lg shadow p-6" do |f| %>
  <% if ballot.errors.any? %>
    <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded">
      <ul class="list-disc list-inside text-red-700 text-sm">
        <% ballot.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <label class="block text-sm font-medium text-gray-700 mb-1">Name <span class="text-gray-400 font-normal">(optional — auto-generated if blank)</span></label>
    <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-md", placeholder: "e.g., 2026 General Election" %>
  </div>

  <div class="mb-4">
    <label class="block text-sm font-medium text-gray-700 mb-1">Election <span class="text-gray-400 font-normal">(link this ballot to an election)</span></label>
    <%= f.select :election_id, @elections.map { |e| [[e.name.presence, e.year, e.state, e.election_type&.titleize].compact.join(' · '), e.id] }, { include_blank: 'None' }, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
  </div>

  <div class="grid grid-cols-2 gap-4 mb-4">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Date</label>
      <%= f.date_field :date, class: "w-full px-3 py-2 border border-gray-300 rounded-md", required: true %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">State</label>
      <%= f.select :state, State.order(:name).pluck(:name, :abbreviation), { include_blank: 'Select state' }, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4 mb-6">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Election Type</label>
      <%= f.select :election_type, Ballot::ELECTION_TYPES.map { |t| [t.titleize, t] }, { include_blank: 'Select type' }, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Party <span class="text-gray-400 font-normal">(required for primary)</span></label>
      <%= f.select :party, @party_options, { include_blank: 'No party' }, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", ballot.persisted? ? admin_ballot_path(ballot) : admin_ballots_path, class: "px-4 py-2 text-gray-700 hover:text-gray-900" %>
    <%= f.submit ballot.persisted? ? "Save Changes" : "Create Ballot", class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 cursor-pointer" %>
  </div>
<% end %>
