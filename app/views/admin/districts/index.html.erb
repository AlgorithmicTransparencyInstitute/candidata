<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Districts</h1>
    <%= link_to "New District", new_admin_district_path, class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-lg shadow mb-6 p-4">
    <%= form_with url: admin_districts_path, method: :get, class: "flex flex-wrap gap-4 items-end" do %>
      <div class="flex-1 min-w-[200px]">
        <label class="block text-sm font-medium text-gray-700 mb-1">Search</label>
        <%= text_field_tag :q, params[:q], placeholder: "OCD-ID, state, or district #…", class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">State</label>
        <%= select_tag :state, options_for_select([['All States', '']] + @states, params[:state]), class: "px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Level</label>
        <%= select_tag :level, options_for_select([['All Levels', ''], ['Federal', 'federal'], ['State', 'state'], ['Local', 'local']], params[:level]), class: "px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Chamber</label>
        <%= select_tag :chamber, options_for_select([['All Chambers', ''], ['Upper', 'upper'], ['Lower', 'lower']], params[:chamber]), class: "px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <%= submit_tag "Filter", class: "px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300 cursor-pointer" %>
      </div>
      <% if params[:q].present? || params[:state].present? || params[:level].present? || params[:chamber].present? %>
        <div><%= link_to "Clear", admin_districts_path, class: "px-4 py-2 text-gray-600 hover:text-gray-900" %></div>
      <% end %>
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Full Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">State</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Level</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Chamber</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">District #</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">OCD-ID</th>
          <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Offices</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @districts.each do |district| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <%= link_to district.full_name, admin_district_path(district), class: "text-blue-600 hover:text-blue-800 font-medium" %>
            </td>
            <td class="px-6 py-4 text-gray-600"><%= district.state %></td>
            <td class="px-6 py-4">
              <span class="px-2 py-1 text-xs rounded-full <%= district.level == 'federal' ? 'bg-purple-100 text-purple-800' : district.level == 'state' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                <%= district.level&.titleize %>
              </span>
            </td>
            <td class="px-6 py-4 text-gray-600"><%= district.chamber&.titleize %></td>
            <td class="px-6 py-4 text-gray-600"><%= district.district_number %></td>
            <td class="px-6 py-4 text-gray-500 text-xs font-mono"><%= district.ocdid %></td>
            <td class="px-6 py-4 text-center">
              <% count = @office_counts[district.id] || 0 %>
              <% if count.positive? %>
                <%= link_to count, admin_district_path(district), class: "text-blue-600 hover:text-blue-800" %>
              <% else %>
                <span class="text-gray-400">0</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right">
              <%= link_to "Edit", edit_admin_district_path(district), class: "text-blue-600 hover:text-blue-800 mr-3" %>
              <%= button_to "Delete", admin_district_path(district), method: :delete,
                  data: { turbo_confirm: "Delete #{district.full_name}?" },
                  class: "text-red-600 hover:text-red-800" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @districts.empty? %>
      <div class="text-center py-12">
        <p class="text-gray-500">No districts yet</p>
      </div>
    <% end %>
  </div>

  <div class="mt-4">
    <%= paginate @districts %>
  </div>
</div>
